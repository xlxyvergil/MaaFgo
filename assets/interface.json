{
    "interface_version": 2,
    "name": "MaaFgo",
    "description": "FGO自动战斗工具",
    "contact": "QQ群: 123456789",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MaaFgo!",
    "github": "https://github.com/MaaXYZ/MaaPracticeBoilerplate",
    "version": "1.0.0",
    "controller": [
        {
            "name": "安卓设备",
            "type": "Adb",
            "display_short_side": 720
        },
        {
            "name": "BBC窗口",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "BBchannel",
                "screencap": "PrintWindow",
                "mouse": "PostMessageWithCursorPos",
                "keyboard": "PostMessageWithCursorPos"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "embedded": true,
        "child_args": [
            "./agent/main.py"
        ]
    },
    "task": [
        {
            "name": "日常战斗",
            "entry": "日常战斗",
            "option": [
                "chapter",
                "quest_chapter1",
                "quest_chapter2",
                "quest_chapter3",
                "team_index",
                "bbc_team_config",
                "bbc_run_count",
                "apple_type",
                "autoBG",
                "effect",
                "showAssistSettingBeforeStart",
                "autoConnect",
                "capMethod",
                "adbori",
                "adbtouch",
                "maxtouch"
            ]
        }
    ],
    "option": {
        "chapter": {
            "type": "select",
            "label": "章节",
            "cases": [
                {
                    "name": "第一章",
                    "label": "第一章",
                    "option": ["quest_chapter1"],
                    "pipeline_override": {
                        "Navigation": {
                            "custom_action_param": {
                                "chapter": "第一章"
                            }
                        }
                    }
                },
                {
                    "name": "第二章",
                    "label": "第二章",
                    "option": ["quest_chapter2"],
                    "pipeline_override": {
                        "Navigation": {
                            "custom_action_param": {
                                "chapter": "第二章"
                            }
                        }
                    }
                },
                {
                    "name": "第三章",
                    "label": "第三章",
                    "option": ["quest_chapter3"],
                    "pipeline_override": {
                        "Navigation": {
                            "custom_action_param": {
                                "chapter": "第三章"
                            }
                        }
                    }
                }
            ]
        },
        "quest_chapter1": {
            "type": "select",
            "label": "关卡",
            "cases": [
                {"name": "第一节", "label": "第一节", "pipeline_override": {"Navigation": {"custom_action_param": {"stage": "第一节"}}}},
                {"name": "第二节", "label": "第二节", "pipeline_override": {"Navigation": {"custom_action_param": {"stage": "第二节"}}}},
                {"name": "第三节", "label": "第三节", "pipeline_override": {"Navigation": {"custom_action_param": {"stage": "第三节"}}}}
            ]
        },
        "quest_chapter2": {
            "type": "select",
            "label": "关卡",
            "cases": [
                {"name": "第一节", "label": "第一节", "pipeline_override": {"Navigation": {"custom_action_param": {"stage": "第一节"}}}},
                {"name": "第二节", "label": "第二节", "pipeline_override": {"Navigation": {"custom_action_param": {"stage": "第二节"}}}}
            ]
        },
        "quest_chapter3": {
            "type": "select",
            "label": "关卡",
            "cases": [
                {"name": "第一节", "label": "第一节", "pipeline_override": {"Navigation": {"custom_action_param": {"stage": "第一节"}}}},
                {"name": "第二节", "label": "第二节", "pipeline_override": {"Navigation": {"custom_action_param": {"stage": "第二节"}}}},
                {"name": "第三节", "label": "第三节", "pipeline_override": {"Navigation": {"custom_action_param": {"stage": "第三节"}}}},
                {"name": "第四节", "label": "第四节", "pipeline_override": {"Navigation": {"custom_action_param": {"stage": "第四节"}}}}
            ]
        },
        "team_index": {
            "type": "select",
            "label": "队伍编号",
            "cases": [
                {"name": "1", "label": "队伍1"},
                {"name": "2", "label": "队伍2"},
                {"name": "3", "label": "队伍3"},
                {"name": "4", "label": "队伍4"},
                {"name": "5", "label": "队伍5"},
                {"name": "6", "label": "队伍6"},
                {"name": "7", "label": "队伍7"},
                {"name": "8", "label": "队伍8"},
                {"name": "9", "label": "队伍9"},
                {"name": "10", "label": "队伍10"},
                {"name": "11", "label": "队伍11"},
                {"name": "12", "label": "队伍12"},
                {"name": "13", "label": "队伍13"},
                {"name": "14", "label": "队伍14"},
                {"name": "15", "label": "队伍15"}
            ],
            "default": "1"
        },
        "bbc_team_config": {
            "type": "input",
            "label": "BBC队伍配置文件名称",
            "default": "default"
        },
        "bbc_run_count": {
            "type": "input",
            "label": "运行次数",
            "default": "1"
        },
        "apple_type": {
            "type": "select",
            "label": "苹果类型",
            "cases": [
                {
                    "name": "copper",
                    "label": "铜苹果"
                },
                {
                    "name": "silver",
                    "label": "银苹果"
                },
                {
                    "name": "gold",
                    "label": "金苹果"
                },
                {
                    "name": "blue",
                    "label": "蓝苹果"
                },
                {
                    "name": "colorful",
                    "label": "彩苹果"
                }
            ]
        },
        "autoBG": {
            "type": "switch",
            "label": "自动轮换背景",
            "default": true
        },
        "effect": {
            "type": "switch",
            "label": "动态效果",
            "default": false
        },
        "showAssistSettingBeforeStart": {
            "type": "switch",
            "label": "开始前显示助战设置",
            "default": false
        },
        "autoConnect": {
            "type": "switch",
            "label": "自动连接",
            "default": false
        },
        "capMethod": {
            "type": "select",
            "label": "截屏方式",
            "cases": [
                {
                    "name": "Javacap",
                    "label": "Javacap"
                },
                {
                    "name": "Minicap",
                    "label": "Minicap"
                },
                {
                    "name": "Adbcap",
                    "label": "Adbcap"
                }
            ]
        },
        "adbori": {
            "type": "switch",
            "label": "使用ADB方向",
            "default": false
        },
        "adbtouch": {
            "type": "switch",
            "label": "使用ADB触摸",
            "default": false
        },
        "maxtouch": {
            "type": "switch",
            "label": "使用MAX触摸",
            "default": false
        }
    }
}
